{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../isomorphic-auth" },
    { "path": "../isomorphic-mesh" },
    { "path": "../isomorphic-registry" },
    { "path": "../raft-consensus" }
  ]
}
